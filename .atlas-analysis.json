  "publicApiSurface": [
    "AI_Manager - Core AI management and orchestration",
    "PromptManager - Prompt template management system",
    "$o - Switch to OpenAI model",
    "$c - Switch to Claude model",
    "$g - Switch to Gemini model",
    "$x - Switch to Grok model",
    "$a - Switch to OpenAI Assistants API",
    "$join - Join voice channel",
    "$leave - Leave voice channel",
    "$talk - Text-to-speech in voice chat",
    "$voice - Change TTS voice",
    "$respond - AI response in voice chat",
    "$ping - Check bot status",
    "$archive - Archive Discord emojis",
    "$music - Search and share music",
    "chat plugin - AI-powered conversation handling",
    "beacon plugin - Data serialization and persistence",
    "self-commands plugin - Bot self-command execution",
    "term-commands plugin - Terminal command integration",
