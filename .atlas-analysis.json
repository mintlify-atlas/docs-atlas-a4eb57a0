  "keyFeatures": [
    "Multi-model AI integration supporting OpenAI, Claude, Gemini, Mistral, Grok, and Perplexity",
    "Voice chat capabilities with text-to-speech and speech recognition",
    "Natural language command processing",
    "Extensible plugin system with dependency management",
    "Chat history management and context awareness",
    "Image generation support with DALL-E and Imagen",
    "Discord emoji archiving and management",
    "Terminal command execution through Discord"
